<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>

{%- assign demo_url = product.metafields.custom.url | default: '' -%}
{%- assign product_form_id = 'product-form-' | append: section.id -%}
{%- assign title_escaped = product.title | escape -%}

{%- comment -%} Header height variable set in layout/theme.liquid as --header-h {%- endcomment -%}

<!-- ══════════════════════════════════════════
     PDP — 2-col layout desktop / single-col mobile
══════════════════════════════════════════ -->
<section
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
  class="grid grid-cols-1 lg:grid-cols-[55%_45%] w-full lg:items-start"
>

  <!-- ══ COLUMNA IZQUIERDA: mockups desktop ══ -->
  <div class="hidden lg:flex flex-col items-center justify-center bg-wb-ivory border-r border-wb-linen px-7 py-12 sticky top-0 self-start" style="height: 100vh;">

    <!-- MacBook: ≥1300px -->
    <div class="pdp-macbook-wrap hidden xl:flex flex-col items-center w-[90%] max-w-225">
      <div class="sticky top-0 w-full z-10">
        <div class="w-full bg-[#1d1d1f] rounded-t-[10px] pt-2.5 px-2.5 pdp-mock-glow" style="box-shadow: 0 0 0 1px #0a0a0a, 0 0 0 2.5px #2a2a2c, 0 16px 48px rgba(0,0,0,.5);">
          <div class="flex items-center gap-1.5 px-2 pb-2 pt-0.5">
            <div class="w-2 h-2 rounded-full bg-[#ff5f57]"></div>
            <div class="w-2 h-2 rounded-full bg-[#ffbd2e]"></div>
            <div class="w-2 h-2 rounded-full bg-[#27c93f]"></div>
            <div class="flex-1 bg-white/[0.07] rounded px-2.5 py-0.5 text-[8.5px] text-white/30 tracking-[.05em] text-center">
              {%- if demo_url != '' -%}{{ demo_url | remove: 'https://' | remove: 'http://' | split: '/' | first }}{%- else -%}preview.invitacion.com{%- endif -%}
            </div>
          </div>
          <div class="pdp-screen bg-white w-full overflow-hidden relative" id="pdpMacScreen">
            {%- if demo_url != '' -%}
              <iframe src="{{ demo_url }}" frameborder="0" loading="lazy" title="{{ title_escaped }} — Preview" class="pdp-iframe origin-top-left block border-0 w-360"></iframe>
            {%- else -%}
              <div class="flex items-center justify-center h-full min-h-48 text-wb-brown-soft text-[11px] tracking-widest text-center p-5">Vista previa disponible</div>
            {%- endif -%}
            <div class="pdp-scroll-overlay absolute inset-0 flex flex-col items-center justify-center gap-2 pointer-events-none" style="backdrop-filter: blur(3px); background: rgba(15,10,8,0.32);">
              <svg width="28" height="36" viewBox="0 0 28 36" fill="none" style="color:#fff;opacity:.9"><rect x="9.5" y="2" width="9" height="18" rx="4.5" stroke="currentColor" stroke-width="2"/><path d="M14 22v10M9 28l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span style="font-size:9px;letter-spacing:.35em;text-transform:uppercase;color:rgba(255,255,255,.75);">Scroll</span>
            </div>
          </div>
          <div class="w-full h-3.5 rounded-b bg-linear-to-b from-[#242424] to-[#1a1a1a]" style="box-shadow: 0 0 0 1px #0a0a0a;"></div>
        </div>
      </div>
      <div class="w-full h-2 rounded-b-sm bg-linear-to-b from-[#c8c0b8] to-[#b0a8a0]" style="box-shadow: 0 2px 8px rgba(0,0,0,.2), 0 0 0 1px rgba(0,0,0,.15);"></div>
      <div class="w-[68%] h-0.75 rounded-b bg-linear-to-b from-[#b8b0a8] to-[#a8a098] mx-auto" style="box-shadow: 0 2px 6px rgba(0,0,0,.15);"></div>
    </div>

    <!-- iPad: 1024–1299px -->
    <div class="pdp-ipad-wrap hidden xl:hidden lg:flex flex-col items-center w-4/5 mx-auto">
      <div class="sticky top-0 w-full z-10">
        <div class="w-full bg-[#1c1c1e] rounded-[20px] px-2.5 py-4 pdp-mock-glow" style="box-shadow: 0 0 0 1px #0a0a0a, 0 0 0 2px #2a2a2c, 0 20px 50px rgba(0,0,0,.4);">
          <div class="w-1.5 h-1.5 rounded-full bg-[#2a2a2c] mx-auto mb-2"></div>
          <div class="pdp-screen bg-white rounded-sm overflow-hidden relative" id="pdpIpadScreen">
            {%- if demo_url != '' -%}
              <iframe src="{{ demo_url }}" frameborder="0" loading="lazy" title="{{ title_escaped }} — Preview" class="pdp-iframe-tablet origin-top-left block border-0 w-5xl"></iframe>
            {%- else -%}
              <div class="flex items-center justify-center h-full text-wb-brown-soft text-[11px] tracking-widest text-center p-5">Vista previa disponible</div>
            {%- endif -%}
            <div class="pdp-scroll-overlay absolute inset-0 flex flex-col items-center justify-center gap-2 pointer-events-none" style="backdrop-filter: blur(3px); background: rgba(15,10,8,0.32);">
              <svg width="28" height="36" viewBox="0 0 28 36" fill="none" style="color:#fff;opacity:.9"><rect x="9.5" y="2" width="9" height="18" rx="4.5" stroke="currentColor" stroke-width="2"/><path d="M14 22v10M9 28l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span style="font-size:9px;letter-spacing:.35em;text-transform:uppercase;color:rgba(255,255,255,.75);">Scroll</span>
            </div>
          </div>
          <div class="w-9 h-1 bg-[#2a2a2c] rounded-[3px] mx-auto mt-2.5"></div>
        </div>
      </div>
    </div>

  </div><!-- /col-left -->

  <!-- ══ COLUMNA DERECHA: info producto ══ -->
  <div class="px-8 lg:px-14 py-14">

    <product-info
      id="ProductInfo-{{ section.id }}"
      data-section="{{ section.id }}"
      data-url="{{ product.url }}"
    >

      <!-- Hero: badge, título, estrellas, precio, descripción -->
      <div class="flex flex-col gap-2.5 opacity-0 translate-y-5 transition-[opacity,transform] duration-700 pdp-reveal">
        <div class="inline-flex items-center gap-2 bg-wb-gold-pale text-wb-gold text-[10px] tracking-[.35em] uppercase px-3.5 py-1.5 self-start lg:self-start max-lg:self-center">
          {{ section.settings.badge }}
        </div>

        <h1 class="font-wb-serif text-wb-brown font-normal leading-[.9] italic max-lg:text-center" style="font-size: clamp(44px, 4.5vw, 72px);">{{ product.title }}</h1>

        <div class="flex items-center gap-2.5 max-lg:justify-center">
          <span class="text-wb-gold text-[13px] tracking-[2px]">★★★★★</span>
          <span class="text-[12px] text-wb-brown-soft">{{ section.settings.stars_label }}</span>
        </div>

        <div class="flex items-baseline gap-2 max-lg:justify-center">
          <span class="text-[11px] tracking-[.2em] uppercase text-wb-brown-soft/70 font-medium">USD</span>
          <div id="price-{{ section.id }}" role="status" class="[&_.price__badges]:hidden [&_.price]:flex [&_.price]:max-lg:justify-center [&_.price__sale]:max-lg:justify-center [&_.price__regular]:max-lg:justify-center [&_.price__compare]:max-lg:justify-center">
            {%- render 'price', product: product, use_variant: true, show_badges: false, price_class: 'price--large' -%}
          </div>
        </div>

        {%- if product.description != blank -%}
          <p class="font-wb-serif text-[18px] italic text-wb-brown-mid leading-relaxed max-lg:text-center max-lg:mb-8">{{ product.description | strip_html }}</p>
        {%- endif -%}
      </div>

      <!-- ── Slot mobile: iPhone <700px / MacBook 700-1024px ── -->
      <div class="pdp-slot hidden max-lg:flex justify-center items-center py-6 bg-wb-parchment -mx-8 px-5">

        <!-- iPhone: solo <700px -->
        <div class="pdp-slot-iphone hidden max-sm2:flex flex-col items-center">
          <div class="relative bg-[#1c1c1e] rounded-[44px] p-3 w-66" style="box-shadow: 0 0 0 1px #0a0a0a, 0 0 0 2px #2a2a2c, 0 24px 60px rgba(0,0,0,.5);">
            <div class="absolute top-3 left-1/2 -translate-x-1/2 w-22.5 h-6.5 bg-[#1c1c1e] rounded-[20px] z-10"></div>
            <div class="absolute -right-0.75 top-22.5 w-0.75 h-13 bg-[#161618] rounded-r-[3px]"></div>
            <div class="absolute -left-0.75 top-18 w-0.75 h-7.5 bg-[#161618] rounded-l-[3px]"></div>
            <div class="absolute -left-0.75 top-29 w-0.75 h-11.5 bg-[#161618] rounded-l-[3px]"></div>
            <div class="absolute -left-0.75 top-43.5 w-0.75 h-11.5 bg-[#161618] rounded-l-[3px]"></div>
            <div class="bg-white rounded-4xl overflow-hidden h-115 relative" id="pdpIphoneScreen">
              {%- if demo_url != '' -%}
                <iframe src="{{ demo_url }}" frameborder="0" loading="lazy" title="{{ title_escaped }} — Preview" class="pdp-iframe-phone origin-top-left block border-0 w-107.5"></iframe>
              {%- else -%}
                <div class="flex items-center justify-center h-full text-wb-brown-soft text-[11px] text-center p-5">Vista previa disponible</div>
              {%- endif -%}
              <div class="pdp-scroll-overlay absolute inset-0 flex flex-col items-center justify-center gap-2 pointer-events-none rounded-4xl" style="backdrop-filter: blur(3px); background: rgba(15,10,8,0.32);">
                <svg width="22" height="30" viewBox="0 0 28 36" fill="none" style="color:#fff;opacity:.9"><rect x="9.5" y="2" width="9" height="18" rx="4.5" stroke="currentColor" stroke-width="2"/><path d="M14 22v10M9 28l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span style="font-size:8px;letter-spacing:.35em;text-transform:uppercase;color:rgba(255,255,255,.75);">Scroll</span>
              </div>
            </div>
          </div>
        </div>

        <!-- MacBook inline: 700px–1023px -->
        <div class="pdp-slot-macbook hidden sm2:flex max-lg:flex flex-col items-center w-full max-w-145">
          <div class="sticky top-0 w-full z-10">
            <div class="w-full bg-[#1d1d1f] rounded-t-[10px] pt-2.5 px-2.5" style="box-shadow: 0 0 0 1px #0a0a0a, 0 0 0 2.5px #2a2a2c, 0 16px 48px rgba(0,0,0,.5);">
              <div class="flex items-center gap-1.5 px-2 pb-2 pt-0.5">
                <div class="w-2 h-2 rounded-full bg-[#ff5f57]"></div>
                <div class="w-2 h-2 rounded-full bg-[#ffbd2e]"></div>
                <div class="w-2 h-2 rounded-full bg-[#27c93f]"></div>
                <div class="flex-1 bg-white/[0.07] rounded px-2.5 py-0.5 text-[8.5px] text-white/30 tracking-[.05em] text-center">
                  {%- if demo_url != '' -%}{{ demo_url | remove: 'https://' | remove: 'http://' | split: '/' | first }}{%- else -%}preview.invitacion.com{%- endif -%}
                </div>
              </div>
              <div class="pdp-screen bg-white w-full overflow-hidden relative" id="pdpMacScreenMobile">
                {%- if demo_url != '' -%}
                  <iframe src="{{ demo_url }}" frameborder="0" loading="lazy" title="{{ title_escaped }} — Preview" class="pdp-iframe origin-top-left block border-0 w-360"></iframe>
                {%- else -%}
                  <div class="flex items-center justify-center h-48 text-wb-brown-soft text-[11px] text-center p-5">Vista previa disponible</div>
                {%- endif -%}
                <div class="pdp-scroll-overlay absolute inset-0 flex flex-col items-center justify-center gap-2 pointer-events-none" style="backdrop-filter: blur(3px); background: rgba(15,10,8,0.32);">
                  <svg width="28" height="36" viewBox="0 0 28 36" fill="none" style="color:#fff;opacity:.9"><rect x="9.5" y="2" width="9" height="18" rx="4.5" stroke="currentColor" stroke-width="2"/><path d="M14 22v10M9 28l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span style="font-size:9px;letter-spacing:.35em;text-transform:uppercase;color:rgba(255,255,255,.75);">Scroll</span>
                </div>
              </div>
              <div class="w-full h-3.5 rounded-b bg-linear-to-b from-[#242424] to-[#1a1a1a]" style="box-shadow: 0 0 0 1px #0a0a0a;"></div>
            </div>
          </div>
          <div class="w-full h-2 rounded-b-sm bg-linear-to-b from-[#c8c0b8] to-[#b0a8a0]" style="box-shadow: 0 2px 8px rgba(0,0,0,.2), 0 0 0 1px rgba(0,0,0,.15);"></div>
          <div class="w-[68%] h-0.75 rounded-b bg-linear-to-b from-[#b8b0a8] to-[#a8a098] mx-auto" style="box-shadow: 0 2px 6px rgba(0,0,0,.15);"></div>
        </div>

      </div><!-- /pdp-slot -->

      <!-- Botones CTA + pills -->
      <div class="flex flex-col gap-4 mt-5 opacity-0 translate-y-5 transition-[opacity,transform] duration-700 delay-100 pdp-reveal">
        <div class="flex flex-col lg:flex-row gap-3">

          {%- form 'product', product, id: product_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %} class="product-variant-id">
            <input type="hidden" name="quantity" value="1">
            <button
              id="ProductSubmitButton-{{ section.id }}"
              type="submit"
              name="add"
              class="bg-wb-blush text-white text-[10px] tracking-[.3em] uppercase px-7 py-3.5 border-0 cursor-pointer font-medium transition-colors duration-300 hover:bg-wb-blush-deep disabled:opacity-50 w-full lg:w-auto whitespace-nowrap js-pdp-buy"
              {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
            >
              {%- if product.selected_or_first_available_variant.available == false -%}Agotado{%- else -%}{{ section.settings.cta_label }} →{%- endif -%}
            </button>
          {%- endform -%}

          {%- if demo_url != '' -%}
            <a href="{{ demo_url }}" target="_blank" rel="noopener noreferrer" class="text-wb-brown-mid text-[10px] tracking-[.25em] uppercase px-5.5 py-3.5 border border-wb-linen transition-all duration-300 hover:border-wb-blush hover:text-wb-blush-deep text-center whitespace-nowrap">
              {{ section.settings.demo_label }}
            </a>
          {%- endif -%}
        </div>

        <div class="flex flex-wrap gap-2 max-lg:justify-center">
          {%- if section.settings.pill_1 != blank -%}<div class="flex items-center gap-1.5 bg-white border border-wb-linen px-3.5 py-1.5 text-[12px] text-wb-brown-mid">{{ section.settings.pill_1 }}</div>{%- endif -%}
          {%- if section.settings.pill_2 != blank -%}<div class="flex items-center gap-1.5 bg-white border border-wb-linen px-3.5 py-1.5 text-[12px] text-wb-brown-mid">{{ section.settings.pill_2 }}</div>{%- endif -%}
          {%- if section.settings.pill_3 != blank -%}<div class="flex items-center gap-1.5 bg-white border border-wb-linen px-3.5 py-1.5 text-[12px] text-wb-brown-mid">{{ section.settings.pill_3 }}</div>{%- endif -%}
          {%- if section.settings.pill_4 != blank -%}<div class="flex items-center gap-1.5 bg-white border border-wb-linen px-3.5 py-1.5 text-[12px] text-wb-brown-mid">{{ section.settings.pill_4 }}</div>{%- endif -%}
        </div>
      </div>

      <!-- Contenido detallado -->
      <div class="mt-10 flex flex-col gap-14">

        <!-- Qué incluye -->
        {%- if section.settings.includes_title != blank -%}
          <div class="opacity-0 translate-y-5 transition-[opacity,transform] duration-700 pdp-reveal">
            <div class="font-wb-serif text-[28px] italic text-wb-brown mb-5 pb-3.5 border-b border-wb-linen flex items-center gap-3 before:content-[''] before:w-4 before:h-0.5 before:bg-wb-blush before:shrink-0">
              {{ section.settings.includes_title }}
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {%- for block in section.blocks -%}
                {%- if block.type == 'include_item' -%}
                  <div class="flex items-start gap-3 p-4 bg-white border border-wb-linen hover:border-wb-blush-pale transition-colors duration-200" {{ block.shopify_attributes }}>
                    <span class="text-[18px] shrink-0 mt-0.5">{{ block.settings.icon }}</span>
                    <div>
                      <div class="text-[13px] font-medium text-wb-brown mb-0.5">{{ block.settings.name }}</div>
                      <div class="text-[12px] text-wb-brown-soft leading-relaxed">{{ block.settings.description }}</div>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        <!-- Cómo funciona -->
        {%- if section.settings.steps_title != blank -%}
          <div id="como-funciona" class="opacity-0 translate-y-5 transition-[opacity,transform] duration-700 pdp-reveal">
            <div class="font-wb-serif text-[28px] italic text-wb-brown mb-5 pb-3.5 border-b border-wb-linen flex items-center gap-3 before:content-[''] before:w-4 before:h-0.5 before:bg-wb-blush before:shrink-0">
              {{ section.settings.steps_title }}
            </div>
            <div class="flex flex-col">
              {%- for block in section.blocks -%}
                {%- if block.type == 'step_item' -%}
                  <div class="grid pb-7 last:pb-0" style="grid-template-columns: 36px 1px 1fr; gap: 0 20px;" {{ block.shopify_attributes }}>
                    <div class="font-wb-serif text-[26px] italic text-wb-blush text-right pt-0.5 leading-none">{{ block.settings.number }}</div>
                    <div class="bg-wb-linen relative before:content-[''] before:absolute before:top-2 before:left-1/2 before:-translate-x-1/2 before:w-1.5 before:h-1.5 before:bg-wb-blush before:rounded-full"></div>
                    <div class="pl-1">
                      <div class="text-[14px] font-medium text-wb-brown mb-1">{{ block.settings.title }}</div>
                      <div class="text-[13px] text-wb-brown-mid leading-[1.65]">{{ block.settings.description }}</div>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        <!-- Nota -->
        {%- if section.settings.note != blank -%}
          <div class="bg-wb-gold-pale border border-wb-gold/20 px-5.5 py-4.5 text-[13px] text-wb-brown-mid leading-[1.7] opacity-0 translate-y-5 transition-[opacity,transform] duration-700 pdp-reveal">
            {{ section.settings.note }}
          </div>
        {%- endif -%}

        <!-- Garantías -->
        <div class="grid grid-cols-1 sm:grid-cols-3 border border-wb-linen bg-white opacity-0 translate-y-5 transition-[opacity,transform] duration-700 pdp-reveal">
          {%- for block in section.blocks -%}
            {%- if block.type == 'guarantee_item' -%}
              <div class="px-4 py-5 text-center border-r border-b border-wb-linen last:border-r-0 sm:nth-[3n]:border-r-0 sm:border-b-0 last:border-b-0" {{ block.shopify_attributes }}>
                <span class="text-[20px] mb-1.5 block">{{ block.settings.icon }}</span>
                <div class="text-[12px] font-medium text-wb-brown mb-0.5">{{ block.settings.title }}</div>
                <div class="text-[11px] text-wb-brown-soft leading-snug">{{ block.settings.description }}</div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <!-- CTA final -->
        <div class="flex flex-col gap-2.5 mt-0 opacity-0 translate-y-5 transition-[opacity,transform] duration-700 pdp-reveal">
          {%- assign final_form_id = 'product-form-final-' | append: section.id -%}
          {%- form 'product', product, id: final_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %} class="product-variant-id">
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              name="add"
              class="w-full bg-wb-blush text-white text-[10px] tracking-[.3em] uppercase py-3.5 border-0 cursor-pointer font-medium transition-colors duration-300 hover:bg-wb-blush-deep disabled:opacity-50 js-pdp-buy"
              {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
            >
              {%- if product.selected_or_first_available_variant.available == false -%}Agotado{%- else -%}{{ section.settings.cta_label }} →{%- endif -%}
            </button>
          {%- endform -%}

          {%- if demo_url != '' -%}
            <a href="{{ demo_url }}" target="_blank" rel="noopener noreferrer" class="w-full text-wb-brown-mid text-[10px] tracking-[.25em] uppercase py-3.5 border border-wb-linen transition-all duration-300 hover:border-wb-blush hover:text-wb-blush-deep text-center block">
              {{ section.settings.demo_label_final }}
            </a>
          {%- endif -%}
        </div>

      </div><!-- /content -->

    </product-info>
  </div><!-- /col-right -->

</section>

<style>
/* MacBook screen heights */
@media (min-width: 1701px) { #pdpMacScreen { height: 500px !important; } }
@media (min-width: 1280px) and (max-width: 1700px) { #pdpMacScreen { height: 350px; } }

/* iframe: 1440px wide, scaled to container via JS */
.pdp-iframe {
  transform-origin: top left;
  border: none;
  display: block;
}
.pdp-iframe-tablet {
  transform-origin: top left;
  border: none;
  display: block;
}
.pdp-iframe-phone {
  transform-origin: top left;
  border: none;
  display: block;
}

/* Slot mobile — hidden by default, flex below 1024px */
@media (max-width: 1023px) {
  .pdp-slot { display: flex !important; }
}

/* iPhone slot: only <580px (sm2 = 580px) */
@media (max-width: 579px) {
  .pdp-slot-iphone { display: flex !important; }
  .pdp-slot-macbook { display: none !important; }
}
/* MacBook inline: 580px–1023px */
@media (min-width: 580px) and (max-width: 1023px) {
  .pdp-slot-iphone { display: none !important; }
  .pdp-slot-macbook { display: flex !important; }
}

/* MacBook inline screen height */
#pdpMacScreenMobile { height: 260px; }
@media (min-width: 768px) and (max-width: 1023px) { #pdpMacScreenMobile { height: 320px; } }

/* Reveal */
.pdp-reveal.pdp-visible { opacity: 1 !important; transform: none !important; }

/* Overlay scroll hint — aparece y desaparece */
@keyframes pdp-overlay-fade {
  0%   { opacity: 0; }
  15%  { opacity: 1; }
  80%  { opacity: 1; }
  100% { opacity: 0; pointer-events: none; }
}
@keyframes pdp-icon-bounce {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(7px); }
}
.pdp-scroll-overlay {
  animation: pdp-overlay-fade 2.8s ease-in-out 0.5s 1 forwards;
  opacity: 0;
}
.pdp-scroll-overlay svg {
  animation: pdp-icon-bounce 0.9s ease-in-out 0.7s 3;
}
</style>

<script>
(function () {
  /* ── Escalar iframes según tipo ── */
  function scaleIframeGroup(selector, viewportW) {
    document.querySelectorAll(selector).forEach(function (iframe) {
      var screen = iframe.parentElement;
      if (!screen) return;
      var w = screen.offsetWidth;
      if (!w) return;
      var scale = w / viewportW;
      iframe.style.transform = 'scale(' + scale + ')';
      var screenH = screen.offsetHeight || parseInt(screen.style.height, 10) || 350;
      iframe.style.height = Math.ceil(screenH / scale) + 'px';
      iframe.style.width = viewportW + 'px';
    });
  }

  function scalePdpIframes() {
    /* MacBook desktop: simula 1440px */
    scaleIframeGroup('.pdp-iframe', 1440);

    /* Tablet desktop (1024–1299px): simula 1024px, máximo 80% de (100vh - header) */
    var ipadScreen = document.getElementById('pdpIpadScreen');
    if (ipadScreen) {
      var headerH = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-h')) || 80;
      var maxH = Math.floor((window.innerHeight - headerH) * 0.8);
      ipadScreen.style.height = maxH + 'px';
    }
    scaleIframeGroup('.pdp-iframe-tablet', 1024);

    /* iPhone: simula 430px */
    scaleIframeGroup('.pdp-iframe-phone', 430);
  }

  scalePdpIframes();
  window.addEventListener('resize', scalePdpIframes);

  /* ── Reveal on scroll ── */
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) e.target.classList.add('pdp-visible');
    });
  }, { threshold: 0.06 });
  document.querySelectorAll('.pdp-reveal').forEach(function (el) { obs.observe(el); });

  /* ── Checkout directo — bypass carrito ── */
  document.querySelectorAll('[data-type="add-to-cart-form"]').forEach(function (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      e.stopImmediatePropagation();
      var variantId = form.querySelector('[name="id"]').value;
      var btn = form.querySelector('button[type="submit"]');
      if (btn) { btn.disabled = true; btn.textContent = '...'; }
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
      }).then(function () {
        window.location.href = '/checkout';
      }).catch(function () {
        if (btn) { btn.disabled = false; btn.textContent = btn.dataset.label || 'Quiero esta plantilla →'; }
      });
    });
  });
})();
</script>

