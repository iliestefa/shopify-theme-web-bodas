<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>

<section
  id="MainProduct-{{ section.id }}"
  class="bg-wb-parchment py-16 md:py-24"
  data-section="{{ section.id }}"
>
  <div class="c-container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-20 items-start">

      <div class="w-full">
        <a class="skip-to-content-link sr-only" href="#ProductInfo-{{ section.id }}">
          {{- 'accessibility.skip_to_product_info' | t -}}
        </a>
        {%- render 'product-media-gallery' -%}
      </div>

      <div class="w-full">
        <product-info
          id="ProductInfo-{{ section.id }}"
          data-section="{{ section.id }}"
          data-url="{{ product.url }}"
          class="flex flex-col gap-8 {% if section.settings.enable_sticky_info %} md:sticky md:top-28 {% endif %}"
        >
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          <div class="flex flex-col gap-3 border-b border-wb-linen pb-8">
            {%- if product.vendor != blank -%}
              <p class="text-[11px] tracking-[0.2em] uppercase text-wb-blush">{{ product.vendor }}</p>
            {%- endif -%}

            <h1 class="font-wb-serif text-[42px] italic text-wb-brown leading-tight md-down:text-[32px]">
              {{ product.title }}
            </h1>

            <div id="price-{{ section.id }}" role="status">
              {%- render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' -%}
            </div>
          </div>

          {%- if product.description != blank -%}
            <div class="richtext text-[15px] leading-relaxed text-wb-brown-mid">
              {{ product.description }}
            </div>
          {%- endif -%}

          {%- unless product.has_only_default_variant -%}
            <div>
              {% render 'product-variant-picker', product: product, product_form_id: product_form_id %}
            </div>
          {%- endunless -%}

          <div class="flex flex-col gap-4">
            {%- form 'product', product, id: product_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input
                type="hidden"
                name="id"
                value="{{ product.selected_or_first_available_variant.id }}"
                {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                class="product-variant-id"
              >
              <input type="hidden" name="quantity" value="1">

              <button
                id="ProductSubmitButton-{{ section.id }}"
                type="submit"
                name="add"
                class="js-add-to-cart w-full text-[11px] tracking-[0.2em] uppercase bg-wb-blush text-white py-4 hover:bg-wb-blush-deep transition-colors duration-300 font-medium"
                {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
              >
                {%- if product.selected_or_first_available_variant.available == false -%}
                  Agotado
                {%- else -%}
                  Elegir esta plantilla
                {%- endif -%}
              </button>

              {{- form | payment_button -}}
            {%- endform -%}

            <p class="text-[12px] tracking-[0.05em] text-wb-brown-soft text-center">
              Entrega en 48 horas · Link personalizado listo para compartir
            </p>
          </div>

          <div class="border-t border-wb-linen pt-6 grid grid-cols-3 gap-4 text-center">
            <div class="flex flex-col items-center gap-1.5">
              <span class="text-[20px]">⏱</span>
              <span class="text-[11px] tracking-[0.1em] uppercase text-wb-brown-mid">48 horas</span>
            </div>
            <div class="flex flex-col items-center gap-1.5">
              <span class="text-[20px]">✏️</span>
              <span class="text-[11px] tracking-[0.1em] uppercase text-wb-brown-mid">1 revisión</span>
            </div>
            <div class="flex flex-col items-center gap-1.5">
              <span class="text-[20px]">📱</span>
              <span class="text-[11px] tracking-[0.1em] uppercase text-wb-brown-mid">100% responsive</span>
            </div>
          </div>

        </product-info>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Information",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "default": true,
      "label": "Enable sticky content on desktop"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
