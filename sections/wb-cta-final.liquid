<div class="text-center py-28 px-16 md-down:px-6 md-down:py-16 xs-down:px-4 xs-down:py-14" style="background: linear-gradient(160deg, #f0e0dd 0%, #e8d4cf 100%);">
  <div class="wb-section-label justify-center before:hidden">{{ section.settings.label_text }}</div>

  {%- if section.settings.script_text != blank -%}
    <span class="wb-script block mt-4 mb-3">{{ section.settings.script_text }}</span>
  {%- endif -%}

  {%- if section.settings.title != blank -%}
    <h2 class="wb-section-title max-w-140 mx-auto mb-7 md-down:max-w-full">{{ section.settings.title }}</h2>
  {%- endif -%}

  {%- if section.settings.description != blank -%}
    <div class="richtext text-[15px] text-wb-brown-mid leading-[1.7] max-w-110 mx-auto mb-9 [&_p]:text-wb-brown-mid [&_p]:mb-0 [&_p]:whitespace-normal [&_a]:text-wb-brown-mid [&_a]:no-underline md-down:text-[14px] md-down:max-w-full">
      {{ section.settings.description }}
    </div>
  {%- endif -%}

  {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
    <a href="{{ section.settings.cta_url }}" class="wb-btn-primary md-down:w-full md-down:max-w-70 md-down:mx-auto">
      {{ section.settings.cta_text }}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Web Bodas — CTA Final",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "label_text",
      "label": "Section Label",
      "default": "Empieza hoy"
    },
    {
      "type": "inline_richtext",
      "id": "script_text",
      "label": "Script/Decorative Text",
      "default": "Tu gran día merece una gran invitación"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Elige tu plantilla y <em>enamora</em> a tus invitados"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>En 48 horas tendrás una invitación digital que tus invitados nunca olvidarán.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Ver las 3 plantillas"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Web Bodas — CTA Final"
    }
  ]
}
{% endschema %}
