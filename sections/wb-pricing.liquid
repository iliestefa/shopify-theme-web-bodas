<div class="bg-wb-ivory py-28 md-down:py-16">
  <div class="c-container">
    <div class="wb-section-label">{{ section.settings.label_text }}</div>

    <!-- Pricing card -->
    <div class="relative overflow-hidden bg-white border border-wb-linen shadow-[0_12px_60px_rgba(74,55,40,0.07)] grid grid-cols-2 gap-20 p-20 items-center mt-10 lg-down:grid-cols-1 lg-down:gap-10 lg-down:p-12 md-down:p-6 md-down:gap-8 md-down:mt-6">

      <!-- Decorative glow — oculto en móvil -->
      <div class="absolute -top-20 -right-20 w-70 h-70 rounded-full pointer-events-none md-down:hidden" style="background: radial-gradient(circle, rgba(232,180,176,0.15), transparent);"></div>

      <!-- Left: price + includes -->
      <div>
        <p class="text-[10px] tracking-[0.45em] uppercase text-wb-brown-soft mb-3">{{ section.settings.price_label }}</p>
        <div class="font-wb-serif italic text-wb-brown leading-none" style="font-size: clamp(56px, 9vw, 108px);">
          <span class="text-[22px] align-super mr-1 text-wb-blush-deep">$</span>{{ section.settings.price }}<span class="text-[18px] font-sans font-light text-wb-brown-soft not-italic">USD</span>
        </div>

        <div class="mt-8 flex flex-col gap-3">
          {%- for block in section.blocks -%}
            <div class="flex items-start gap-3" {{ block.shopify_attributes }}>
              <div class="w-5 h-5 shrink-0 mt-px rounded-full bg-wb-blush-pale flex items-center justify-center text-[10px] text-wb-blush-deep">✓</div>
              <div class="richtext text-[14px] text-wb-brown-mid [&_p]:text-wb-brown-mid [&_p]:mb-0 [&_p]:whitespace-normal [&_a]:text-wb-brown-mid [&_a]:no-underline">{{ block.settings.item_text }}</div>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.price_note != blank -%}
          <div class="richtext mt-6 pt-6 border-t border-wb-linen text-[13px] leading-[1.7] text-wb-brown-soft [&_p]:text-wb-brown-soft [&_p]:mb-0 [&_p]:whitespace-normal [&_strong]:text-wb-blush-deep [&_a]:text-wb-brown-soft [&_a]:no-underline">
            {{ section.settings.price_note }}
          </div>
        {%- endif -%}
      </div>

      <!-- Right: CTA -->
      <div class="flex flex-col items-start gap-5">
        <div class="wb-section-label mb-0!">{{ section.settings.cta_label }}</div>

        {%- if section.settings.headline != blank -%}
          <p class="font-wb-serif text-[30px] italic text-wb-brown leading-tight md-down:text-[26px]">{{ section.settings.headline }}</p>
        {%- endif -%}

        <div class="inline-flex items-center gap-2.5 bg-wb-gold-pale px-4 py-3 text-[13px] text-wb-brown-mid">
          ⏱&nbsp;<span class="text-wb-brown font-medium">{{ section.settings.delivery_text }}</span>
        </div>

        {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="wb-btn-primary mt-2 md-down:w-full md-down:text-center">
            {{ section.settings.cta_text }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Web Bodas — Pricing",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "label_text",
      "label": "Section Label",
      "default": "Inversión"
    },
    {
      "type": "inline_richtext",
      "id": "price_label",
      "label": "Price Label",
      "default": "precio único · todo incluido"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "49"
    },
    {
      "type": "richtext",
      "id": "price_note",
      "label": "Price Note",
      "default": "<p><strong>¿Necesitas un cambio después de recibir tu invitación?</strong><br />Con gusto lo realizamos. El tiempo de entrega de la modificación es también de <strong>48 horas</strong>, sin costo adicional.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "¿Lista para empezar?"
    },
    {
      "type": "inline_richtext",
      "id": "headline",
      "label": "CTA Headline",
      "default": "Elige tu plantilla y cuéntanos tu historia de amor"
    },
    {
      "type": "inline_richtext",
      "id": "delivery_text",
      "label": "Delivery Text",
      "default": "Entrega garantizada en 48 horas"
    },
    {
      "type": "inline_richtext",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Elegir mi plantilla"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Inclusion",
      "settings": [
        {
          "type": "richtext",
          "id": "item_text",
          "label": "Item Text",
          "default": "<p>Página web personalizada en la plantilla elegida</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Web Bodas — Pricing",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "item_text": "<p>Página web personalizada en la plantilla elegida</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "item_text": "<p>Entrega en máximo 48 horas tras confirmar el pago</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "item_text": "<p>100% responsive: móvil, tablet y desktop</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "item_text": "<p>Link personalizado listo para compartir</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "item_text": "<p>Una revisión de cambios incluida sin costo</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "item_text": "<p>Página activa por 12 meses</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
