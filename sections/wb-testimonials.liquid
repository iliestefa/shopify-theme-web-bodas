<div class="bg-wb-blush-pale py-28 md-down:py-16">
  <div class="c-container">
    <div class="wb-section-label">{{ section.settings.label_text }}</div>

    {%- if section.settings.title != blank -%}
      <h2 class="wb-section-title mt-5">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="grid grid-cols-3 gap-8 mt-16 lg-down:grid-cols-1 lg-down:gap-6 lg-down:mt-10">
      {%- for block in section.blocks -%}
        <div class="relative bg-white border border-wb-linen px-7 py-9 shadow-[0_4px_24px_rgba(74,55,40,0.05)] md-down:px-5 md-down:py-7" {{ block.shopify_attributes }}>
          <!-- Decorative quote mark -->
          <span class="absolute -top-4 left-5 font-wb-serif text-[72px] leading-none text-[rgba(232,180,176,0.25)] pointer-events-none select-none md-down:text-[56px]">"</span>

          {%- if block.settings.quote != blank -%}
            <div class="richtext text-[14px] leading-[1.8] text-wb-brown-mid mb-6 [&_p]:text-wb-brown-mid [&_p]:mb-0 [&_p]:whitespace-normal [&_a]:text-wb-brown-mid [&_a]:no-underline">
              {{ block.settings.quote }}
            </div>
          {%- endif -%}

          <div class="flex items-center gap-3">
            {%- if block.settings.avatar_initial != blank -%}
              <div class="w-10 h-10 shrink-0 rounded-full bg-wb-blush-pale border border-wb-blush flex items-center justify-center font-wb-serif italic text-[16px] text-wb-blush-deep">
                {{ block.settings.avatar_initial }}
              </div>
            {%- endif -%}
            <div>
              {%- if block.settings.author_name != blank -%}
                <div class="font-wb-serif italic text-wb-brown text-[16px]">{{ block.settings.author_name }}</div>
              {%- endif -%}
              {%- if block.settings.template_name != blank -%}
                <div class="text-[11px] tracking-widest text-wb-brown-soft">{{ block.settings.template_name }}</div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Web Bodas — Testimonials",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "label_text",
      "label": "Section Label",
      "default": "Parejas felices"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Section Title",
      "default": "Ellos ya dijeron <em>sí</em>"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "richtext",
          "id": "quote",
          "label": "Quote",
          "default": "<p>Superó todas nuestras expectativas. La recibimos en menos de 24 horas y nuestros invitados no paraban de decir lo hermosa que era. ¡La recomendamos totalmente!</p>"
        },
        {
          "type": "inline_richtext",
          "id": "avatar_initial",
          "label": "Avatar Initial",
          "default": "C"
        },
        {
          "type": "inline_richtext",
          "id": "author_name",
          "label": "Author Name",
          "default": "Camila &amp; Rodrigo"
        },
        {
          "type": "inline_richtext",
          "id": "template_name",
          "label": "Template Used",
          "default": "Plantilla Clásica"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Web Bodas — Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "<p>Superó todas nuestras expectativas. La recibimos en menos de 24 horas y nuestros invitados no paraban de decir lo hermosa que era. ¡La recomendamos totalmente!</p>",
            "avatar_initial": "C",
            "author_name": "Camila &amp; Rodrigo",
            "template_name": "Plantilla Clásica"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "<p>Pedimos un pequeño cambio en los colores y lo tuvieron listo al día siguiente. El proceso fue súper fácil y el resultado fue exactamente lo que soñábamos.</p>",
            "avatar_initial": "L",
            "author_name": "Luciana &amp; Felipe",
            "template_name": "Plantilla Romántica"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "<p>Buscábamos algo moderno y diferente. La plantilla Elegante fue perfecta para nosotros. Todos nuestros amigos preguntaron quién la hizo. ¡Vale cada centavo!</p>",
            "avatar_initial": "V",
            "author_name": "Valentina &amp; Marco",
            "template_name": "Plantilla Elegante"
          }
        }
      ]
    }
  ]
}
{% endschema %}
