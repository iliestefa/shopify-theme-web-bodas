<div id="plantillas" class="bg-wb-parchment py-28 md-down:py-18">
  <!-- Intro -->
  <div class="c-container grid grid-cols-[1fr_auto] gap-20 items-end mb-18 lg-down:grid-cols-1 lg-down:gap-6 md-down:mb-10">
    <div>
      <div class="wb-section-label">{{ section.settings.label_text }}</div>
      {%- if section.settings.title != blank -%}
        <div class="wb-section-title">{{ section.settings.title }}</div>
      {%- endif -%}
    </div>
    {%- if section.settings.intro_text != blank -%}
      <div class="richtext text-[15px] leading-[1.8] text-wb-brown-mid max-w-85 lg-down:max-w-full [&_p]:text-wb-brown-mid [&_p]:mb-0 [&_p]:whitespace-normal [&_a]:text-wb-brown-mid [&_a]:no-underline">
        {{ section.settings.intro_text }}
      </div>
    {%- endif -%}
  </div>

  <!-- Grid de productos -->
  {%- assign products_collection = collections[section.settings.collection] -%}
  {%- if products_collection != blank and products_collection.products_count > 0 -%}
    <div class="c-container grid grid-cols-3 gap-8 lg-down:grid-cols-1 lg-down:gap-6">
      {%- for product in products_collection.products limit: section.settings.products_limit -%}
        {%- assign product_image_alt = product.title | escape -%}
        <a
          href="{{ product.url }}"
          class="group cursor-pointer no-underline block transition-transform duration-400 ease-out hover:-translate-y-1.5"
        >
          <!-- Thumbnail -->
          <div class="relative h-115 overflow-hidden border border-wb-linen shadow-[0_8px_40px_rgba(74,55,40,0.07)] md-down:h-95">
            {%- if product.featured_image != blank -%}
              {%- render 'image',
                image: product.featured_image,
                class: 'w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]',
                alt: product_image_alt,
                widths: '480,640,900'
              -%}
            {%- else -%}
              <div class="w-full h-full flex items-center justify-center bg-wb-ivory text-wb-brown-soft text-[13px] italic font-wb-serif">
                {{ product.title }}
              </div>
            {%- endif -%}

            <!-- Badge tipo -->
            {%- if product.type != blank -%}
              <div class="absolute top-3.5 right-3.5 z-10 text-[9px] tracking-[0.25em] uppercase px-3.5 py-1.5 border font-normal bg-wb-gold-pale text-wb-gold border-wb-linen">
                {{ product.type }}
              </div>
            {%- endif -%}
          </div>

          <!-- Info -->
          <div class="pt-7 pb-0 px-1">
            <div class="font-wb-serif text-[26px] italic text-wb-brown mb-2">{{ product.title }}</div>
            {%- if product.description != blank -%}
              <p class="text-[13px] leading-[1.7] text-wb-brown-mid mb-5">{{ product.description | strip_html | truncate: 130 }}</p>
            {%- endif -%}
            <span class="inline-flex items-center gap-2 text-[11px] tracking-[0.3em] uppercase text-wb-blush-deep no-underline border-b border-wb-blush-pale pb-0.5 group-hover:border-wb-blush-deep transition-colors duration-300">
              Ver preview y personalizar →
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <!-- Fallback: bloques manuales si no hay colección configurada -->
    <div class="c-container grid grid-cols-3 gap-8 lg-down:grid-cols-1 lg-down:gap-6">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.cta_url | default: '#' }}"
          class="group cursor-pointer no-underline block transition-transform duration-400 ease-out hover:-translate-y-1.5"
          {{ block.shopify_attributes }}
        >
          <div class="relative h-115 overflow-hidden border border-wb-linen shadow-[0_8px_40px_rgba(74,55,40,0.07)] md-down:h-95">
            <div class="w-full h-full flex flex-col items-center justify-center px-8 py-10 text-center transition-transform duration-500 ease-out group-hover:scale-[1.02] bg-wb-ivory">
              <div class="font-wb-serif text-[26px] italic text-wb-brown">{{ block.settings.name }}</div>
            </div>
            {%- if block.settings.badge != blank -%}
              <div class="absolute top-3.5 right-3.5 z-10 text-[9px] tracking-[0.25em] uppercase px-3.5 py-1.5 border font-normal bg-wb-gold-pale text-wb-gold border-wb-linen">
                {{ block.settings.badge }}
              </div>
            {%- endif -%}
          </div>
          <div class="pt-7 pb-0 px-1">
            <div class="font-wb-serif text-[26px] italic text-wb-brown mb-2">{{ block.settings.name }}</div>
            {%- if block.settings.description != blank -%}
              <div class="richtext text-[13px] leading-[1.7] text-wb-brown-mid mb-5 [&_p]:text-wb-brown-mid [&_p]:mb-0">{{ block.settings.description }}</div>
            {%- endif -%}
            <span class="inline-flex items-center gap-2 text-[11px] tracking-[0.3em] uppercase text-wb-blush-deep border-b border-wb-blush-pale pb-0.5 group-hover:border-wb-blush-deep transition-colors duration-300">
              Ver preview y personalizar →
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Web Bodas — Plantillas",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "label_text",
      "label": "Label de sección",
      "default": "Plantillas"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Título",
      "default": "Tres estilos, <em>una sola historia</em>"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Texto intro",
      "default": "<p>Haz clic en cualquier plantilla para ver su preview completo y personalizar tu invitación.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección de plantillas"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Máximo de productos a mostrar",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "blocks": [
    {
      "type": "template",
      "name": "Plantilla manual (fallback)",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "badge",
          "label": "Badge",
          "default": "Clásica"
        },
        {
          "type": "inline_richtext",
          "id": "name",
          "label": "Nombre",
          "default": "La Clásica"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Descripción",
          "default": "<p>Elegancia atemporal en tonos crema y dorado.</p>"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "URL del producto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Web Bodas — Plantillas"
    }
  ]
}
{% endschema %}
