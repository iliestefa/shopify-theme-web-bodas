<div id="como-funciona" class="bg-wb-ivory py-28 md-down:py-18">
  <div class="c-container">
    <div class="wb-section-label">{{ section.settings.label_text }}</div>

    {%- if section.settings.title != blank -%}
      <h2 class="wb-section-title mt-5">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="grid grid-cols-4 gap-12 mt-18 lg-down:grid-cols-2 lg-down:gap-8 md-down:grid-cols-1 md-down:gap-6 md-down:mt-10">
      {%- for block in section.blocks -%}
        <div class="relative" {{ block.shopify_attributes }}>
          {%- if block.settings.step_number != blank -%}
            <div class="font-wb-serif text-[15px] italic text-wb-blush tracking-[0.2em] mb-5">— {{ block.settings.step_number }}</div>
          {%- endif -%}

          {%- if block.settings.icon != blank -%}
            <div class="w-13 h-13 bg-white border border-wb-linen rounded-full flex items-center justify-center text-[22px] mb-5 shadow-[0_4px_20px_rgba(74,55,40,0.06)]">
              {{ block.settings.icon }}
            </div>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h3 class="font-wb-serif text-[22px] italic text-wb-brown mb-2.5">{{ block.settings.heading }}</h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <div class="richtext text-[14px] leading-[1.75] text-wb-brown-mid [&_p]:text-wb-brown-mid [&_p]:mb-0 [&_p]:whitespace-normal [&_a]:text-wb-brown-mid [&_a]:no-underline">
              {{ block.settings.description }}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Web Bodas — Cómo Funciona",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "label_text",
      "label": "Section Label",
      "default": "El proceso"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Section Title",
      "default": "Tan sencillo como <em>cuatro pasos</em>"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "step_number",
          "label": "Step Number",
          "default": "01"
        },
        {
          "type": "inline_richtext",
          "id": "icon",
          "label": "Icon/Emoji",
          "default": "💎"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Elige tu plantilla"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Explora nuestras 3 plantillas exclusivas y previsualiza cada una antes de decidirte.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Web Bodas — Cómo Funciona",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "01",
            "icon": "💎",
            "heading": "Elige tu plantilla",
            "description": "<p>Explora nuestras 3 plantillas exclusivas y previsualiza cada una antes de decidirte.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "02",
            "icon": "✍️",
            "heading": "Completa tus datos",
            "description": "<p>Llena el formulario con todos los detalles de tu boda: nombres, fecha, lugar y programa.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "03",
            "icon": "💳",
            "heading": "Realiza el pago",
            "description": "<p>Pago seguro y sencillo. En cuanto lo confirmemos, comenzamos a crear tu invitación.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "04",
            "icon": "🎁",
            "heading": "Recibe en 48 hrs",
            "description": "<p>Tu invitación personalizada llegará a tu correo, lista para compartir con tus invitados.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
