<div class="bg-white border-t border-wb-linen border-b py-7 px-10 flex justify-center gap-10 flex-wrap md-down:grid md-down:grid-cols-2 md-down:px-8 md-down:gap-5 md-down:py-6 xs-down:px-5">
  {%- for block in section.blocks -%}
    <div class="flex items-center gap-3.5 text-[13px] text-wb-brown-mid md-down:text-[12px]" {{ block.shopify_attributes }}>
      {%- if block.settings.icon != blank -%}
        <div class="w-9 h-9 bg-wb-blush-pale rounded-full flex items-center justify-center text-[15px] shrink-0">
          {{ block.settings.icon }}
        </div>
      {%- endif -%}
      <div>
        {%- if block.settings.title != blank -%}
          <strong class="font-wb-serif italic text-wb-brown text-[16px] font-normal block leading-none md-down:text-[15px]">{{ block.settings.title }}</strong>
        {%- endif -%}
        {%- if block.settings.label != blank -%}
          {{ block.settings.label }}
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Web Bodas — Features",
  "class": "section",
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "icon",
          "label": "Icon or Emoji",
          "default": "⏱"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title",
          "default": "48 horas"
        },
        {
          "type": "inline_richtext",
          "id": "label",
          "label": "Label",
          "default": "entrega garantizada"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Web Bodas — Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "⏱",
            "title": "48 horas",
            "label": "entrega garantizada"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "✏️",
            "title": "1 revisión",
            "label": "sin costo adicional"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "📱",
            "title": "Responsive",
            "label": "móvil y desktop"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🔗",
            "title": "Link listo",
            "label": "para compartir"
          }
        }
      ]
    }
  ]
}
{% endschema %}
