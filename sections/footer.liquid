<footer class="bg-wb-brown">
  <div class="max-w-300 mx-auto px-16 py-14 flex justify-between items-center flex-wrap gap-7 md-down:flex-col md-down:text-center md-down:px-6 md-down:py-10">

    <div class="font-wb-serif text-[20px] italic text-white/85">
      {%- if settings.logo != blank -%}
        {%- capture logo_style -%}
          max-width: {{ settings.logo_width }}px; filter: brightness(0) invert(1); opacity: 0.85;
        {%- endcapture -%}
        {%- render 'image-element',
          image: settings.logo,
          fixed_width: 300,
          class: 'header__heading-logo',
          style: logo_style
        -%}
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </div>

    {%- if section.settings.copyright != blank -%}
      <small class="text-[12px] tracking-[0.05em] text-white/55">{{ section.settings.copyright }}</small>
    {%- endif -%}

    {%- if section.settings.menu != blank -%}
      <ul class="flex flex-wrap gap-7 md-down:justify-center" role="list">
        {%- for link in section.settings.menu.links -%}
          {%- unless link.url contains '/search' or link.url == routes.search_url -%}
            <li>
              <a
                href="{{ link.url }}"
                class="text-[11px] tracking-[0.2em] uppercase text-white/40 hover:text-wb-blush transition-colors duration-300"
              >
                {{- link.title | escape -}}
              </a>
            </li>
          {%- endunless -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "limit": 1,
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú de footer",
      "default": "footer"
    },
    {
      "type": "inline_richtext",
      "id": "copyright",
      "label": "Copyright",
      "default": "© 2025 · Diseñado con amor para cada historia"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
