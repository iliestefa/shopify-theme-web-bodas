<footer class="bg-wb-brown">
  <div class="c-container py-14 flex justify-between items-center flex-wrap gap-7 md-down:flex-col md-down:text-center md-down:py-10">
    <div class="font-wb-serif text-[20px] italic text-white/85">
      {%- if settings.logo != blank -%}
        {%- capture logo_style -%}
          max-width: {{ settings.logo_width }}px; filter: brightness(0) invert(1); opacity: 0.85;
        {%- endcapture -%}
        {%- render 'image-element',
          image: settings.logo,
          fixed_width: 300,
          class: 'header__heading-logo',
          style: logo_style
        -%}
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </div>

    {%- if section.settings.copyright != blank -%}
      <small class="text-[12px] tracking-[0.05em] text-white/55">{{ section.settings.copyright }}</small>
    {%- endif -%}

    {%- if settings.social_instagram_link != blank or settings.social_tiktok_link != blank -%}
      <div class="flex items-center gap-5">
        {%- if settings.social_instagram_link != blank -%}
          <a
            href="{{ settings.social_instagram_link }}"
            aria-label="Instagram"
            class="text-white/55 hover:text-white transition-colors duration-300"
          >
            {%- render 'icon', icon: 'instagram' -%}
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a
            href="{{ settings.social_tiktok_link }}"
            aria-label="TikTok"
            class="text-white/55 hover:text-white transition-colors duration-300"
          >
            {%- render 'icon', icon: 'tiktok' -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "limit": 1,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "copyright",
      "label": "Copyright",
      "default": "© 2025 · Diseñado con amor para cada historia"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
