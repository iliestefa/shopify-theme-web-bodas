<nav class="hidden lg:flex">
  <ul class="flex flex-row items-center gap-8" role="list">
    {%- for link in section.settings.menu.links -%}
      <li>
        <a
          href="{{ link.url }}"
          class="text-[12px] tracking-[0.2em] uppercase text-wb-brown-soft hover:text-wb-brown transition-colors duration-300{% if link.current %} text-wb-brown font-medium{% endif %}"
          {% if link.current %}aria-current="page"{% endif %}
        >
          {{- link.title | escape -}}
        </a>
      </li>
    {%- endfor -%}
  </ul>
</nav>
